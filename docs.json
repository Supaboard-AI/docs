{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Supaboard Docs",
  "colors": {
    "primary": "#2e8ff2",
    "light": "#0b99ff",
    "dark": "#2376ca"
  },
  "favicon": "https://framerusercontent.com/images/0S3XhBBKzV0qjE4LjhFxGAHazU.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "icon": "/icons/report.svg",
          "href": "https://supaboard.ai/blogs"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Docs",
        "icon": "/icons/help.svg",
        "groups": [
          {
            "group": "Getting started",
            "icon": "/icons/rocket.svg",
            "pages": ["index", "quickstart", "development"]
          },
          {
            "group": "Features",
            "icon": "/icons/star.svg",
            "pages": [
              "workspace",
              "ask-agents",
              "agents",
              "data-sources",
              "dashboard",
              "tools",
              "white-label",
              "embed",
              "query-builder"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "icon": "/icons/bulb.svg",
        "groups": [
          {
            "group": "Data Sources",
            "icon": "/icons/data.svg",
            "pages": [
              "big-query",
              "clickhouse",
              "databricks",
              "fivetran",
              "microsoft-sql-server",
              "mongodb",
              "mysql",
              "postgres",
              "redshift",
              "snowflake",
              "supabase"
            ]
          },
          {
            "group": "Visualisation",
            "icon": "/icons/chart.svg",
            "pages": [
              "table-widget",
              "chart-widget",
              "kpi-widget",
              "insights-in-ask-agents",
              "insights-in-dashboard"
            ]
          },
          {
            "group": "Best Practices",
            "icon": "/icons/checklist.svg",
            "pages": [
              "interacting-with-ai",
              "writing-sql-queries"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/logo-light.png",
    "dark": "/images/logo-dark.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://auth.supaboard.ai/onboard/register"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "styling": {
    "eyebrows": "section"
  },
  "fonts": {
    "family": "fkGroteskNeue",
    "weight": 400,
    "source": "https://r2cdn.perplexity.ai/fonts/FKGroteskNeue.woff2",
    "format": "woff2"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#fafafc",
      "dark": "#161619"
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "thumbnails": {
    "appearance": "light"
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "navigable"
  },
  "interaction": {
    "drilldown": true
  }
}
