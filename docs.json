{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Supaboard Docs",
  "colors": {
    "primary": "#2e8ff2",
    "light": "#0b99ff",
    "dark": "#2376ca"
  },
  "favicon": "https://framerusercontent.com/images/0S3XhBBKzV0qjE4LjhFxGAHazU.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "icon": "book-bookmark",
          "href": "https://supaboard.ai/blogs"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "icon": "life-ring",
        "groups": [
          {
            "group": "Getting started",
            "icon": "flag-checkered",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Features",
            "icon": "flag-swallowtail",
            "pages": [
              "workspace",
              "ask-agents",
              "agents",
              "data-sources",
              "dashboard",
              "tools",
              "white-label",
              "embed",
              "query-builder"
            ]
          }
        ]
      },
      {
        "tab": "Data Sources"
      },
      {
        "tab": "Learn"
      }
    ]
  },
  "logo": {
    "light": "/images/logo-light.png",
    "dark": "/images/logo-dark.png"
  },
  "navbar": {
    "links": [
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://auth.supaboard.ai/onboard/register"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "styling": {
    "eyebrows": "section"
  },
  "fonts": {
    "family": "fkGroteskNeue",
    "weight": 400,
    "source": "https://r2cdn.perplexity.ai/fonts/FKGroteskNeue.woff2",
    "format": "woff2"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#fafafc",
      "dark": "#161619"
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "thumbnails": {
    "appearance": "light"
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "navigable"
  },
  "interaction": {
    "drilldown": true
  }
}
